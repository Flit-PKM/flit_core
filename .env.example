# Environment
ENVIRONMENT=development

# Server
# PORT=8000  # Used when running 'python -m main'. For 'uvicorn main:app', export and use: --port $PORT

# Security - REQUIRED: Must be at least 32 characters long
SECRET_KEY=your-secret-key-here-change-in-production-minimum-32-characters

# Logging
LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Database backend: postgres (default) or d1 (Cloudflare D1)
DB_BACKEND=postgres

# PostgreSQL (required when DB_BACKEND=postgres)
# Alternative for Render and similar hosts: set DATABASE_URL instead; then DB_USER, DB_PASSWORD, DB_HOST, DB_PORT, DB_NAME are optional
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_USER=youruser
DB_PASSWORD=my@super#secure!pw
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flit

# Cloudflare D1 (required when DB_BACKEND=d1)
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_API_TOKEN=your-d1-api-token
# CF_DATABASE_ID=your-d1-database-uuid

# Database Connection Pool (optional, PostgreSQL only; defaults shown)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# CORS Origins (optional, defaults to http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Settings (optional, defaults shown)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Token settings (optional, defaults shown)
# OAUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
# OAUTH_REFRESH_TOKEN_EXPIRE_DAYS=1825

# App list override (optional). JSON array of {"slug","name"}, e.g. [{"slug":"flit","name":"Flit"}]
# ALLOWED_APPS_JSON=[{"slug":"flit","name":"Flit"},{"slug":"still","name":"Still"}]

# Connection code flow (optional, defaults shown)
# CONNECTION_CODE_EXPIRE_MINUTES=10
# CONNECTION_CODE_LENGTH=8

# Cloudflare Turnstile (optional; required for POST /subscriptions)
# TURNSTILE_SECRET=your-turnstile-secret-key